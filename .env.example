# ── SERVER ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Comma-separated list for strict CORS allowlist (e.g. https://waizai.example.com,https://admin.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional body size limits
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb

# ── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgresql://waizai_user:yourpassword@localhost:5432/waizai_db

# ── REDIS ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SUPERADMIN ───────────────────────────────────────
SUPERADMIN_SLUG=priyanshu
SUPERADMIN_JWT_SECRET=separate_superadmin_jwt_secret

# ── AI PROVIDERS (Managed by Superadmin) ─────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...
SARVAM_API_KEY=...
DEFAULT_AI_MODEL=claude-sonnet-4-6

# ── GOOGLE CALENDAR ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# ── EMAIL (SendGrid) ─────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@waizai.com
EMAIL_FROM_NAME=WaizAI

# ── SMS / OTP (Twilio) ───────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Optional MSG91 fallback
MSG91_AUTH_KEY=
MSG91_SENDER_ID=WAIZAI
MSG91_TEMPLATE_ID=

# ── PAYMENT (Razorpay) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── FILE STORAGE (AWS S3) ────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=waizai-storage

# ── WHATSAPP / BAILEYS ──────────────────────────────
WA_SESSION_DIR=./whatsapp-auth-state
BAILEYS_LOG_LEVEL=error
WA_RECONNECT_DELAY_MS=3000
WA_BROWSER_VERSION=122.0.0.0
WA_CONNECT_TIMEOUT_MS=60000
WA_QUERY_TIMEOUT_MS=60000
WA_KEEPALIVE_MS=20000
WA_CONNECT_TOKEN_SECRET=your_short_lived_connect_token_secret
WA_CONNECT_TOKEN_TTL_SECONDS=300
# Optional proxy list for automatic egress rotation when WA blocks an IP (comma-separated)
WA_EGRESS_PROXY_URLS=
# Optional fixed/default proxy URL from the list above
WA_EGRESS_PROXY_DEFAULT=

# ── ENCRYPTION ───────────────────────────────────────
ENCRYPTION_KEY=32_char_hex_key_for_encrypting_tokens

# ── RATE LIMITING ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── SAFE SEEDING (Non-production only) ───────────────
# Seeding is blocked unless ALLOW_SEED=true and NODE_ENV is not production.
ALLOW_SEED=false
SUPERADMIN_EMAIL=
SUPERADMIN_NAME=
SUPERADMIN_PASSWORD=
DEMO_EMAIL=
DEMO_PASSWORD=
AFFILIATE_EMAIL=
AFFILIATE_PASSWORD=

# ── FRONTEND BUILD VARS (for docker compose build) ───────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_SUPERADMIN_SLUG=priyanshu
